desc:Spider Router Hub (Safe Mode)
// Uses gmem for stable, crash-free communication
@init
ext_nchan = 8;
// Use gmem[0] as our "On/Off" switch
// gmem is shared memory that won't crash the UI thread

@sample
gmem[0] > 0.5 ? (
  spl2 = spl0; spl3 = spl1;
  spl4 = spl0; spl5 = spl1;
  spl6 = spl0; spl7 = spl1;
);
