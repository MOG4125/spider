desc:Spider Router Hub (Controlled)

slider1:0<0,1,1{Off,On}>Enable Distribution
slider2:0<-60,6,0.1>Gain (dB)

@init
ext_nchan = 8; // Tell REAPER to use 8 channels

@slider
gain = 10^(slider2/20);

@sample
slider1 > 0 ? (
  // Spiders the signal from 1/2 to 3/4, 5/6, and 7/8
  spl2 = spl0 * gain; spl3 = spl1 * gain;
  spl4 = spl0 * gain; spl5 = spl1 * gain;
  spl6 = spl0 * gain; spl7 = spl1 * gain;
);
